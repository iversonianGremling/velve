@edition "2026.6"

-- Inline conditional expression `if c then a else b` — the 2026.6 replacement for
-- the deprecated ternary (`cond ? a : b`). It lowers to the same `If` node, chains
-- right-associatively as an else-if ladder, and nests inside other expressions.

def sign(n: Number): String -> if n > 0 then "pos" else if n < 0 then "neg" else "zero"

def absVal(n: Number): Number -> if n < 0 then 0 - n else n

def clampHi(n: Number, hi: Number): Number -> if n > hi then hi else n

def label(score: Number): String ->
  if score > 90 then "A"
  else if score > 80 then "B"
  else if score > 70 then "C"
  else "F"

def main(): Unit
  print(sign(3))
  print(label(85))
