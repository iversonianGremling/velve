@edition "2026.6"

-- Call children (SPEC §11.1): a bare component call is a CHILD grammar form.
--   Column(gap=8)
--     header()          -- this line — previously not a child form at all
--     row(item)
-- Before this rule, lowercase call lines under an element silently parsed as
-- SIBLING statements of the element (the same demand-driven-indent flattening
-- fixed for paren-form elements), so composed views rendered only their last
-- leaf. Lowercase-headed only: capitalization splits call_child from
-- element_leaf exactly as it splits call from constructor. The old escape
-- hatch `{card()}` still parses (the brace child form).

type Item = { id: Number, label: String }

-- A leaf component with an argument: composition with data flowing in.
def badge(text: String): Element
  Text(text, size=10, color=#9ecbff)

-- A component whose own body uses a call child — two levels of composition.
def row(item: Item): Element
  Row(gap=6)
    Text(item.label, size=12, color=#e8e8e8)
    badge("new")

def panel(): Element
  Column(gap=8, background=#10141c)
    Text("Inbox", size=16, color=#f5f5f5)
    row(#{ id: 1, label: "first" })
    row(#{ id: 2, label: "second" })
    {badge("legacy spelling")}

def main(): ()
  println(uiModel(panel()))
