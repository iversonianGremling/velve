-- Brace escapes: `\{` / `\}` produce literal braces, so JSON-shaped text can be
-- written without triggering interpolation. Other C-style escapes still work.

def main(): Unit
  let x = 5
  println(("plain \{ brace \}"))            -- plain { brace }
  println(("json \{\"k\": {x}\}"))          -- json {"k": 5}   (escape + interpolation)
  println(("tab\there\nnewline"))           -- tab + newline
  println(("quote \" backslash \\ end"))    -- quote " backslash \ end
