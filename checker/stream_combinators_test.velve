-- merge / debounce / throttle stream combinators (SPEC §10.2). Producers drive the
-- virtual clock with `sleep`, so timing is deterministic.

stream MA : Number
stream MB : Number
stream TH : Number
stream DB : Number

-- merge: interleave two sources; Done only after BOTH finish → sum 1+2+10+20 = 33
def prodMA(): Unit
  send MA (Push(1))
  send MA (Push(2))
  send MA Done
def prodMB(): Unit
  send MB (Push(10))
  send MB (Push(20))
  send MB Done

-- throttle 10ms (leading edge): 1 @0 emit; 2 @5 dropped (within window); 3 @55 emit → 1+3 = 4
def prodTH(): Unit
  send TH (Push(1))
  sleep((5))
  send TH (Push(2))
  sleep((50))
  send TH (Push(3))
  send TH Done

-- debounce 10ms (trailing): burst 1,2 → 1 dropped, 2 survives quiet; then 3 after quiet → 2+3 = 5
def prodDB(): Unit
  send DB (Push(1))
  send DB (Push(2))
  sleep((50))
  send DB (Push(3))
  sleep((50))
  send DB Done

def sumOf(s: Stream(Number)): Number
  s |> streamFold(0, (fn (acc x) -> acc + x))

def main(): Number
  go prodMA()
  go prodMB()
  let merged = sumOf((streamMerge(MA, MB)))

  go prodTH()
  let throttled = sumOf((streamThrottle(TH, 10)))

  go prodDB()
  let debounced = sumOf((streamDebounce(DB, 10)))

  println(("merged={merged} throttled={throttled} debounced={debounced}"))
  merged
