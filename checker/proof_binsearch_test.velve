-- The gradient's showcase: ONE recursive binary search carrying BOTH proof
-- obligations at once — `proofs: [bounds, total]` (SPEC §12.6/§12.7).
--
-- The search window is a start `lo` and a length `span`; every step halves it.
-- Two obligations meet here, each on its own discharge:
--
--   • `bounds`: every read `xs[mid]` must be PROVED in range. The guard
--     `mid >= 0 && mid < length(xs)` puts both sides on the sync interval
--     floor — no solver, exactly the guarded-read idiom from proof_bounds_test.
--
--   • `total` (every def in a `proofs: [total]` module is implicitly @total):
--     the measure is `span`, and it must UNIT-DECREASE on every recursive
--     call. The left half recurses on `floor(span / 2)`, which over the REALS
--     does NOT unit-decrease for span ∈ [1, 2) — span/2 there is in [0.5, 1),
--     not ≤ span − 1. What saves it is the FLOOR: ⌊span/2⌋ is pinned to an
--     INTEGER, so on span ∈ [1, 2) it is exactly 0 ≤ span − 1. The Tier-2
--     measure check (terminates.ts) now admits `floor(e)` as a first-class
--     Int-sorted term bracketed by e−1 < ⌊e⌋ ≤ e, the runtime-floor analog of
--     the bounds-soundness argument (0 ≤ i < len ⟹ 0 ≤ ⌊i⌋ < len). The right
--     half recurses on `span − half − 1`, a genuine unit decrease that only
--     needs ⌊span/2⌋ ≥ 0.
--
-- Expected: clean; runs (5 / 0 / 9 / -1 / -1).
@edition "2026.6"

module binsearch
  proofs: [bounds, total]

  -- Returns the index of `target` in the sorted window [lo, lo + span), or -1.
  def search(xs: List(Number), target: Number, lo: Number, span: Number): Number
    let half = floor(span / 2)
    let mid = lo + half
    if span < 1 then -1
    else if mid >= 0 && mid < length(xs) then
      if xs[mid] == target then mid
      else if xs[mid] < target then search(xs, target, mid + 1, span - half - 1)
      else search(xs, target, lo, half)
    else -1

def main(): Effect [io] ()
  let xs = [2, 5, 8, 12, 16, 23, 38, 56, 72, 91]
  println(search(xs, 23, 0, length(xs)))
  println(search(xs, 2, 0, length(xs)))
  println(search(xs, 91, 0, length(xs)))
  println(search(xs, 100, 0, length(xs)))
  println(search(xs, 7, 0, length(xs)))
