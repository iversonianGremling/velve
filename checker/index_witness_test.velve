-- The Tier-1.5 RELATIONAL WITNESS (north-star §3.3, SPEC §12.7). A dependent
-- refinement with the in-range predicate shape, instantiated `Index(length(xs))`
-- over a sibling param, ties an index to THAT list — the tie the InBounds ADT
-- (SPEC §7.1) deliberately cannot express. Two fact-env bridges, both under
-- `proofs: [bounds]`:
--   • SEED (callee): the signature IS the witness — the body assumes
--     0 <= i < length(xs), so the read needs no guard;
--   • DEMAND (caller): every argument at a witness param must be PROVED in
--     range from path facts (interval floor, then Z3) — check once at the
--     guard, spend the witness at as many calls as the branch covers.
-- Outside a proved scope the demand keeps today's skip (the gradient; see
-- main's direct call). Expected: clean; runs.
@edition "2026.6"

type Index n = Number where 0 <= value && value < n

module slots
  proofs: [bounds]

  -- The proof-requiring op: no guard in the body — the witness param seeds
  -- the facts the read needs.
  def at(xs: List(Number), i: Index(length(xs))): Number
    xs[i]

  -- Check once, use many: one guard licenses every demand under it.
  def both(xs: List(Number), i: Number, j: Number): Number
    if i >= 0 && i < length(xs) && j >= 0 && j < length(xs) then at(xs, i) + at(xs, j) else -1

  -- Witness through arithmetic: the demand on `length(xs) - 1` is Z3's
  -- (Int-sorted length turns `> 0` into `>= 1`).
  def lastOf(xs: List(Number)): Number
    if length(xs) > 0 then at(xs, length(xs) - 1) else -1

  -- Relational, positively: one index, two lists, each demand proved against
  -- its OWN list's facts.
  def pairSum(xs: List(Number), ys: List(Number), i: Number): Number
    if i >= 0 && i < length(xs) && i < length(ys) then at(xs, i) + at(ys, i) else -1

def main(): Effect [io] ()
  let xs = [10, 20, 30, 40]
  let ys = [1, 2]
  println(both(xs, 1, 3))    -- 20 + 40
  println(lastOf(xs))        -- 40
  println(pairSum(xs, ys, 1))-- 20 + 2
  println(both(xs, 9, 0))    -- guard rejects: -1
  println(at(xs, 2))         -- outside the proved scope: demand skips (gradient)
