-- SortedList: the §3.2 semantic archetype, now IMPORTED rather than INCLUDED
-- (SPEC §7.3, Phase C1(iii)). The library — a `@private` smart-constructor type
-- whose closed ops preserve sortedness BY CONSTRUCTION — lives once on disk at
-- `std/sorted`; this fixture is just the consumer. The loader merges
-- `module sorted { … }` into the program, so the gates resolve cross-file and
-- the ctor stays sealed at the module-now-file boundary (`sorted_list_bad`
-- exercises the proof vocabulary on the library side).
-- Expected: clean; runs.
@edition "2026.6"

import { sortedList, slValues, slInsert, slMerge, slMin, fromAny } from "std/sorted"

-- Outside the module: the type name is public, values flow through the gates.
def main(): Effect [io] ()
  match sortedList([1, 3, 5])
    | Ok(s) ->
      println(slValues(s))
      println(slValues(slInsert(s, 4)))
      match slMin(s)
        | Ok(m)    -> println(m)
        | Error(_) -> println("?")
    | Error(_) -> println("?")
  match sortedList([3, 1])
    | Ok(_)    -> println("?")
    | Error(e) -> println("gate: {e}")
  println(slValues(slMerge(fromAny([5, 1, 9]), fromAny([2, 8]))))
  match sortedList([])
    | Ok(empty) ->
      match slMin(empty)
        | Ok(_)    -> println("?")
        | Error(e) -> println("min blocked: {e}")
    | Error(_) -> println("?")
