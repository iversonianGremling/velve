-- Each function here should trigger a borrow/lifetime error.

-- 1. dangling: returns a pointer straight to a local
@low
def dangling(): Ptr Number
  let local = 5
  local.&

-- 2. dangling via an intermediate binding
@low
def danglingIndirect(): Ptr Number
  let local = 7
  let p = local.&
  p

-- 3. drop-while-borrowed: x is still borrowed by p when dropped
@low
def dropBorrowed(): Unit
  let x = 9
  let p = x.&
  drop x
  println("{p.*}")
