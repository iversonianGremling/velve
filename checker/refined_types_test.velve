-- The Tier-1 refined-type library (north-star §3.3), now IMPORTED rather than
-- INCLUDED (SPEC §7.3, Phase C1(iii)). The library — Natural / NonZero /
-- Positive / InBounds as `@private` ADTs, correct BY CONSTRUCTION — lives once
-- on disk at `std/refined`; this fixture is just the consumer. The loader merges
-- `module refined { … }` into the program, so the gates resolve cross-file, the
-- `Natural` TYPE name is public, and the `@private` ctors stay sealed at the
-- module-now-file boundary (`refined_types_bad` proves the seal holds).
-- Expected: clean; runs.
@edition "2026.6"

import { natural, natValue, natAdd, natMul, natSub, nonZero, divBy, positive, posToNat, posMul, inBounds, getAt } from "std/refined"

-- Outside the module: type names are public, values flow through the gates.
def show(r: Result Natural String): String
  match r
    | Ok(n)    -> "nat {natValue(n)}"
    | Error(e) -> "no: {e}"

def main(): Effect [io] ()
  println(show(natural(5)))
  println(show(natural(0 - 3)))
  match natural(4)
    | Ok(a) ->
      match natural(7)
        | Ok(b) ->
          println(natValue(natAdd(a, b)))
          println(natValue(natMul(a, b)))
          println(show(natSub(a, b)))
          println(show(natSub(b, a)))
        | Error(_) -> println("?")
    | Error(_) -> println("?")
  match nonZero(4)
    | Ok(d)    -> println(divBy(10, d))
    | Error(_) -> println("?")
  match nonZero(0)
    | Ok(_)    -> println("?")
    | Error(e) -> println("div blocked: {e}")
  match positive(3)
    | Ok(p)    -> println(natValue(posToNat(posMul(p, p))))
    | Error(_) -> println("?")
  let xs = [10, 20, 30]
  match inBounds(2, xs)
    | Ok(ix)   -> println(getAt(xs, ix))
    | Error(_) -> println("?")
  match inBounds(5, xs)
    | Ok(_)    -> println("?")
    | Error(e) -> println("index blocked: {e}")
