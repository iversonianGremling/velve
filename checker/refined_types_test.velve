-- The Tier-1 refined-type library (north-star §3.3): Natural / NonZero /
-- Positive / InBounds as `@private` ADTs. Correct BY CONSTRUCTION, no solver:
-- the smart constructor is the only gate from raw Number (ctors are sealed at
-- the module boundary, SPEC §7.1), closed ops stay in the type, faulting ops
-- return Result. The module is itself proof-carrying — `proofs: [total,
-- exhaustive, handled]` — so every def discharges the gradient it ships.
-- Honest Tier-1 bound: InBounds witnesses an index, not an index-INTO-xs
-- (the relational tie is Tier 1.5's witness-token primitive); same-list
-- discipline is the caller's until then.
-- Expected: clean; runs.
@edition "2026.6"

module refined
  proofs: [total, exhaustive, handled]

  @private
  type Natural
    = Natural Number

  @private
  type NonZero
    = NonZero Number

  @private
  type Positive
    = Positive Number

  @private
  type InBounds
    = InBounds Number

  -- Gates: the only way in from a raw Number.
  def natural(n: Number): Result Natural String
    if n >= 0 then Ok(Natural(n)) else Error("negative")

  def nonZero(n: Number): Result NonZero String
    if n == 0 then Error("zero") else Ok(NonZero(n))

  def positive(n: Number): Result Positive String
    if n > 0 then Ok(Positive(n)) else Error("not positive")

  def inBounds(i: Number, xs: List(a)): Result InBounds String
    if i >= 0 && i < length(xs) then Ok(InBounds(i)) else Error("out of bounds")

  -- Projections: reading is not forging.
  def natValue(n: Natural): Number
    match n
      | Natural(x) -> x

  def nzValue(d: NonZero): Number
    match d
      | NonZero(x) -> x

  def posValue(p: Positive): Number
    match p
      | Positive(x) -> x

  def ibValue(ix: InBounds): Number
    match ix
      | InBounds(x) -> x

  -- Closed ops: Natural + Natural is Natural by construction, no re-check.
  def natAdd(a: Natural, b: Natural): Natural
    Natural(natValue(a) + natValue(b))

  def natMul(a: Natural, b: Natural): Natural
    Natural(natValue(a) * natValue(b))

  -- Faulting op: subtraction can leave the type, so it returns through the gate.
  def natSub(a: Natural, b: Natural): Result Natural String
    natural(natValue(a) - natValue(b))

  def posMul(a: Positive, b: Positive): Positive
    Positive(posValue(a) * posValue(b))

  -- Positive ⊆ Natural: the embedding is closed.
  def posToNat(p: Positive): Natural
    Natural(posValue(p))

  -- Division made total: the witness type deletes the zero case.
  def divBy(n: Number, d: NonZero): Number
    n / nzValue(d)

  -- Indexing made safe: only a checked index reaches the partial kernel.
  def getAt(xs: List(a), ix: InBounds): a
    head(slice(xs, ibValue(ix), ibValue(ix) + 1))

-- Outside the module: type names are public, values flow through the gates.
def show(r: Result Natural String): String
  match r
    | Ok(n)    -> "nat {natValue(n)}"
    | Error(e) -> "no: {e}"

def main(): Effect [io] ()
  println(show(natural(5)))
  println(show(natural(0 - 3)))
  match natural(4)
    | Ok(a) ->
      match natural(7)
        | Ok(b) ->
          println(natValue(natAdd(a, b)))
          println(natValue(natMul(a, b)))
          println(show(natSub(a, b)))
          println(show(natSub(b, a)))
        | Error(_) -> println("?")
    | Error(_) -> println("?")
  match nonZero(4)
    | Ok(d)    -> println(divBy(10, d))
    | Error(_) -> println("?")
  match nonZero(0)
    | Ok(_)    -> println("?")
    | Error(e) -> println("div blocked: {e}")
  match positive(3)
    | Ok(p)    -> println(natValue(posToNat(posMul(p, p))))
    | Error(_) -> println("?")
  let xs = [10, 20, 30]
  match inBounds(2, xs)
    | Ok(ix)   -> println(getAt(xs, ix))
    | Error(_) -> println("?")
  match inBounds(5, xs)
    | Ok(_)    -> println("?")
    | Error(e) -> println("index blocked: {e}")
