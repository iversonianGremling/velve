-- `proofs: [arith]` — the partial-arithmetic-domain obligation (SPEC §12.7),
-- the sixth checkable proof: in a proved scope every call to a domain-
-- restricted math builtin must have its argument PROVED inside the domain.
-- The faults are silent NaNs (`sqrt(-1)`, `log(0)`, `asin(2)` return NaN in
-- JS, not an error) — the same "no error to handle" shape that motivates
-- `nonzero`, and the same engine: the flow-sensitive fact env, interval floor
-- first, Z3 fall-through for what the floor can't settle. Both surface
-- spellings reach the table — ambient `Math.sqrt(x)` and bare `sqrt(x)`.
-- Scope-local like `nonzero`/`bounds`.
-- Expected: clean; runs.
@edition "2026.6"

module mathdom
  proofs: [arith]

  -- if-guard floor: the then arm knows x >= 0 (sqrt's domain).
  def root(x: Number): Number
    if x >= 0 then Math.sqrt(x) else 0

  -- > 0 guard for log's domain.
  def safeLog(x: Number): Number
    if x > 0 then Math.log(x) else 0

  -- two-sided domain for asin: `&&` distributes both -1 <= x and x <= 1.
  def arcsin(x: Number): Number
    if x >= -1 && x <= 1 then Math.asin(x) else 0

  -- literal argument, trivially inside the domain.
  def rootBig(): Number
    Math.sqrt(81)

  -- bare builtin spelling (no `Math.` qualifier) reaches the same table.
  def rootBare(x: Number): Number
    if x >= 0 then sqrt(x) else 0

  -- Z3 residue: a * a is non-negative over the reals, so sqrt's domain holds
  -- with no guard at all — the solver proves what the floor can't.
  def magnitudeSq(a: Number): Number
    Math.sqrt(a * a)

  -- Z3 residue on a guarded difference: a > b entails a - b > 0 for log.
  def logGap(a: Number, b: Number): Number
    if a > b then Math.log(a - b) else 0

def main(): Effect [io] ()
  println(root(9))
  println(safeLog(1))
  println(arcsin(0))
  println(rootBig())
  println(rootBare(16))
  println(magnitudeSq(4))
  println(logGap(3, 2))
