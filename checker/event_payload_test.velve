-- Event payloads: `on onInput e -> …` binds the DOM event to `e`, a typed `Event`
-- record ({ value: String, key: String, checked: Bool }). Forms read `e.value`.

store Form
  state
    name : String = ""
  messages
    SetName(x: String) -> { name: x }
  pub
    current = name

def view(): Element
  Column gap=8 padding=12
    Input id="field" value=(Form.current) placeholder="your name"
      on onInput e -> send Form (SetName(e.value))
    Text "hello {Form.current}" id="greet" size=14 color=#ffffff

def main(): Unit
  print(html(view()))
