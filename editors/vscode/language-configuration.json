{
  "comments": { "lineComment": "--" },
  "brackets": [["(", ")"], ["[", "]"], ["{", "}"]],
  "autoClosingPairs": [
    { "open": "(", "close": ")" },
    { "open": "[", "close": "]" },
    { "open": "{", "close": "}" },
    { "open": "\"", "close": "\"" },
    { "open": "`", "close": "`" }
  ],
  "surroundingPairs": [
    ["(", ")"], ["[", "]"], ["{", "}"], ["\"", "\""]
  ],
  "indentationRules": {
    "increaseIndentPattern": "^.*->\\s*$|^\\s*(def|if|else|match|do|loop|for|machine|saga|store|module)\\b.*$",
    "decreaseIndentPattern": "^\\s*$"
  }
}
